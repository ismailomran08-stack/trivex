{
  "buildCommand": "npm run build",
  "outputDirectory": ".",
  "rewrites": [
    { "source": "/admin", "destination": "/admin.html" },
    { "source": "/services/franchise-construction", "destination": "/services/franchise-construction.html" },
    { "source": "/services/restaurant-construction", "destination": "/services/restaurant-construction.html" },
    { "source": "/services/medical-clinic-construction", "destination": "/services/medical-clinic-construction.html" },
    { "source": "/services/office-commercial-construction", "destination": "/services/office-commercial-construction.html" },
    { "source": "/locations/ontario", "destination": "/locations/ontario.html" },
    { "source": "/locations/nova-scotia", "destination": "/locations/nova-scotia.html" },
    { "source": "/locations/new-brunswick", "destination": "/locations/new-brunswick.html" },
    { "source": "/locations/newfoundland", "destination": "/locations/newfoundland.html" },
    { "source": "/locations/pei", "destination": "/locations/pei.html" },
    { "source": "/locations/manitoba", "destination": "/locations/manitoba.html" },
    { "source": "/locations/saskatchewan", "destination": "/locations/saskatchewan.html" },
    { "source": "/locations/alberta", "destination": "/locations/alberta.html" },
    { "source": "/blog", "destination": "/blog/index.html" },
    { "source": "/blog/choosing-commercial-contractor-canada", "destination": "/blog/choosing-commercial-contractor-canada.html" },
    { "source": "/blog/commercial-construction-permits-canada", "destination": "/blog/commercial-construction-permits-canada.html" },
    { "source": "/blog/franchise-fit-out-checklist", "destination": "/blog/franchise-fit-out-checklist.html" },
    { "source": "/blog/medical-clinic-construction-requirements", "destination": "/blog/medical-clinic-construction-requirements.html" }
  ],
  "headers": [
    {
      "source": "/admin.html",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
